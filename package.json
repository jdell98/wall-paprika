{
  "name": "wall-paprika",
  "version": "0.1.0",
  "description": "Menu bar app for macOS that rotates desktop wallpapers from Unsplash collections",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -n main,renderer \"webpack --config webpack.config.js --env target=main --watch\" \"webpack serve --config webpack.config.js --env target=renderer\"",
    "build": "webpack --config webpack.config.js --env target=main && webpack --config webpack.config.js --env target=preload && webpack --config webpack.config.js --env target=renderer",
    "package": "npm run build && electron-builder",
    "lint": "eslint src/ && prettier --check src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "author": "Jack",
  "license": "MIT",
  "dependencies": {
    "electron-store": "^10.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.0.0",
    "css-loader": "^7.0.0",
    "css-minimizer-webpack-plugin": "^7.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "html-webpack-plugin": "^5.0.0",
    "mini-css-extract-plugin": "^2.0.0",
    "postcss": "^8.0.0",
    "postcss-loader": "^8.0.0",
    "prettier": "^3.0.0",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "ts-loader": "^9.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^6.0.0",
    "webpack-dev-server": "^5.0.0"
  }
}
